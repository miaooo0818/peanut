rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Products: catalog is publicly readable, writeable by client for management
    match /products/{productId} {
      allow read, write: if true;
    }

    // Orders: anyone can read (for looking up orders) and write (submitting orders)
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // Config: used for storing the admin password hash
    match /config/{configId} {
      allow read, write: if true;
    }
  }
}
